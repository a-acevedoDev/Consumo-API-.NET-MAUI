<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StarWarsTCG.ViewModels"
             x:Class="StarWarsTCG.Views.MainPage"
             Title="Star Wars TCG"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <Grid Padding="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Cards}"
                        IsVisible="{Binding ShowCards}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5" 
                            Padding="10" 
                            BackgroundColor="#2a2a2a" 
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="Auto, *, Auto">

                            <Image Source="{Binding FrontArt}" 
                                   WidthRequest="60" 
                                   HeightRequest="80" 
                                   Aspect="AspectFit"/>

                            <StackLayout Grid.Column="1" Margin="10,0,0,0" VerticalOptions="Center">
                                <Label Text="{Binding Name}" 
                                       TextColor="White" 
                                       FontSize="16" 
                                       FontAttributes="Bold"/>

                                <Label Text="{Binding Subtitle}" 
                                       TextColor="#cccccc" 
                                       FontSize="12"
                                       IsVisible="{Binding HasSubtitle}"/>

                                <Label Text="{Binding Rarity}" 
                                       TextColor="#ffd700" 
                                       FontSize="12"/>
                            </StackLayout>

                            <Button Grid.Column="2" 
                                    Text="+" 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, 
                                                      Path=BindingContext.AddToCollectionCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#4CAF50"
                                    TextColor="White"
                                    FontSize="20"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    CornerRadius="20"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="1" 
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#ffd700"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
    </Grid>
</ContentPage>